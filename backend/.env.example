# Copy this file to backend/.env and fill in what you want to run live.
# Everything here is OPTIONAL — with all values blank, Keeper runs fully
# offline: a built-in prompt-aware fallback LLM + local sponsor fallbacks.

# --- The brain ---
# Real Claude (claude-opus-4-8) for planning & scanning; blank => fallbackLlm:
ANTHROPIC_API_KEY=
# ...or route Claude through a Zero.xyz proxy instead of a direct key:
# ANTHROPIC_BASE_URL=

# --- Sponsors (live upgrades; blank => local fallback) ---
# Nexla live auth (else local Nexsets):
# NEXLA_API_KEY=
# NEXLA_API_URL=
# Pomerium live JWT verification (else local policy engine):
# POMERIUM_ISSUER=
# POMERIUM_AUDIENCE=
# Zero.xyz live tool discovery (else curated signal->tool map):
# ZERO_API_URL=

# --- Server ---
# Port the API listens on (the frontend proxies /api/v1 here):
PORT=8787
