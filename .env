# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"

# Keeper backend. Leave unset to use the offline mock (localStorage-backed) —
# the composer→detail flow works with no backend running. Set this to the
# Keeper base URL (e.g. http://localhost:8787) to flip to the real /api/v1.
# VITE_KEEPER_API_URL=http://localhost:8787
