diff --git a/src/http/retry.ts b/src/http/retry.ts
index 1aab3f2..8b0d6e9 100644
--- a/src/http/retry.ts
+++ b/src/http/retry.ts
@@ -1,16 +1,27 @@
-export async function withRetry<T>(operation: () => Promise<T>): Promise<T> {
-  return operation();
+type RetryOptions = {
+  attempts?: number;
+  retryable?: (error: unknown) => boolean;
+};
+
+export async function withRetry<T>(
+  operation: () => Promise<T>,
+  { attempts = 3, retryable = () => true }: RetryOptions = {},
+): Promise<T> {
+  let lastError: unknown;
+
+  for (let attempt = 1; attempt <= attempts; attempt += 1) {
+    try {
+      // The caller's fetch has no AbortSignal here; a stalled upstream can keep
+      // this promise pending forever and the retry budget is never reached.
+      return await operation();
+    } catch (error) {
+      lastError = error;
+      if (!retryable(error) || attempt === attempts) throw error;
+      await new Promise((resolve) => setTimeout(resolve, attempt * 100));
+    }
+  }
+
+  throw lastError;
 }
